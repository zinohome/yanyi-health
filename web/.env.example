# ===== 数据库（PostgreSQL）=====
# 本地开发（直连本机 5432）：
DATABASE_URL=postgresql://yanyi:yanyi_dev_pw@127.0.0.1:5432/yanyi_web
# 生产 docker compose：host 用服务名 postgres，例如：
# DATABASE_URL=postgresql://yanyi:强密码@postgres:5432/yanyi_web

# ===== Payload =====
# 生成随机密钥：openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SITE_URL=https://www.yanyi-health.com

# ===== docker-compose.prod.yml 使用的 Postgres 凭据 =====
POSTGRES_USER=yanyi
POSTGRES_PASSWORD=请设置强密码
POSTGRES_DB=yanyi_web

# ===== 邮件通知（填写后，表单留资自动发到 NOTIFY_EMAIL；163 邮箱用「客户端授权码」作为 SMTP_PASS）=====
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=perffie@163.com
SMTP_PASS=your-163-authorization-code
SMTP_FROM=perffie@163.com
NOTIFY_EMAIL=contact@yanyi-ai.com
