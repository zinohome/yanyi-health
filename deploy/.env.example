# 复制为 .env（与 docker-compose.yml 同目录），填入真实值后再部署。
# 注意：DATABASE_URL 的 host 用 compose 服务名 postgres。

# ===== PostgreSQL =====
POSTGRES_USER=yanyi
POSTGRES_PASSWORD=请设置强密码
POSTGRES_DB=yanyi_web

# ===== 镜像版本 =====
# 默认 latest；指定具体版本（如 v0.1.26）可精确部署并便于回滚
IMAGE_TAG=latest

# ===== 应用 =====
DATABASE_URL=postgresql://yanyi:请设置强密码@postgres:5432/yanyi_web
# 生成：openssl rand -base64 32
PAYLOAD_SECRET=请生成随机密钥
NEXT_PUBLIC_SITE_URL=https://www.yanyi-health.com
# 容器首启自动建表（保持为 1）
PAYLOAD_DB_PUSH=1

# ===== 首次自动创建的后台管理员 =====
SEED_ADMIN_EMAIL=admin@yanyi-health.com
SEED_ADMIN_PASSWORD=Yanyi@2026

# ===== 邮件通知（可选；填写后表单留资自动发到 NOTIFY_EMAIL）=====
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_EMAIL=contact@yanyi-ai.com
